# ============================================================
# CreativeStudio — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
PORT=3000
SITE_URL=http://localhost:3000

# Admin Credentials (used to create first admin user)
ADMIN_USER=admin
ADMIN_PASS=studio2025

# JWT Secret (generate a random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-random-secret-here

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
# SMTP_FROM is now automatic — uses your company name from admin settings
NOTIFY_EMAIL=your-email@gmail.com

# Paystack
PAYSTACK_PUBLIC_KEY=your-paystack-public-key-here
PAYSTACK_SECRET_KEY=your-paystack-secret-key-here
